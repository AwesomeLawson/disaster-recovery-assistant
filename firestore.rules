rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles.hasAny(['administrator']);
    }

    function isAssessor() {
      return isAuthenticated() &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles.hasAny(['assessor']);
    }

    function isWorkGroupLead() {
      return isAuthenticated() &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles.hasAny(['workGroupLead']);
    }

    function isBaseCampHost() {
      return isAuthenticated() &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles.hasAny(['baseCampHost']);
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    match /baseCamps/{baseCampId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /workOrders/{workOrderId} {
      allow read: if isAuthenticated();
      allow create: if isAssessor();
      allow update: if isAssessor() || isAdmin();
      allow delete: if isAdmin();
    }

    match /workgroups/{workgroupId} {
      allow read: if isAuthenticated();
      allow create: if isWorkGroupLead() || isAdmin();
      allow update: if isWorkGroupLead() || isAdmin();
      allow delete: if isAdmin();
    }

    match /escalations/{escalationId} {
      allow read: if isAuthenticated();
      allow create: if isWorkGroupLead() || isAssessor();
      allow update: if isAdmin() || isWorkGroupLead();
      allow delete: if isAdmin();
    }

    match /threads/{threadId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participantIds;
      allow write: if false;
    }

    match /messages/{messageId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /userEventData/{docId} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin() || isWorkGroupLead());
      allow write: if false;
    }

    match /volunteerHours/{docId} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() &&
        (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /legalReleases/{releaseId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /impersonationAudit/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /tools/{toolId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isBaseCampHost();
    }

    match /toolLendings/{lendingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isBaseCampHost();
    }

    // Help Chat — conversations are user-owned; admins can read all.
    // Reads/writes by the owner go through Cloud Functions, but we still
    // permit owner-side reads (UI may subscribe directly later); creates by
    // the owner are allowed for forward compatibility. Mutations that matter
    // (sending messages, deletes) happen server-side.
    match /helpConversations/{conversationId} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
    }

    // Help Chat messages — readable only by the owning user of the
    // conversation; writes only via Cloud Functions.
    match /helpMessages/{messageId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // App config (e.g., Anthropic API key) — never readable or writable
    // from the client. Cloud Functions use the Admin SDK to manage these.
    match /appConfig/{configId} {
      allow read, write: if false;
    }
  }
}