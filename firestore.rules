rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles.hasAny(['administrator']);
    }

    function isAssessor() {
      return isAuthenticated() &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles.hasAny(['assessor']);
    }

    function isWorkGroupLead() {
      return isAuthenticated() &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles.hasAny(['workGroupLead']);
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    match /baseCamps/{baseCampId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /workOrders/{workOrderId} {
      allow read: if isAuthenticated();
      allow create: if isAssessor();
      allow update: if isAssessor() || isAdmin();
      allow delete: if isAdmin();
    }

    match /workgroups/{workgroupId} {
      allow read: if isAuthenticated();
      allow create: if isWorkGroupLead() || isAdmin();
      allow update: if isWorkGroupLead() || isAdmin();
      allow delete: if isAdmin();
    }

    match /escalations/{escalationId} {
      allow read: if isAuthenticated();
      allow create: if isWorkGroupLead() || isAssessor();
      allow update: if isAdmin() || isWorkGroupLead();
      allow delete: if isAdmin();
    }

    match /threads/{threadId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participantIds;
      allow write: if false;
    }

    match /messages/{messageId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /userEventData/{docId} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin() || isWorkGroupLead());
      allow write: if false;
    }

    match /legalReleases/{releaseId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /impersonationAudit/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}